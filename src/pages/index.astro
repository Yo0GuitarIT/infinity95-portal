---
import Layout from "../layouts/Layout.astro";

const links = [
  { name: "Google", url: "https://www.google.com" },
  { name: "Blog", url: "https://infinity95.com" },
  { name: "Astro", url: "https://www.astro.build" },
];

const imageUrl =
  "https://images.unsplash.com/photo-1776798973362-c985f57c08e5?q=80&w=1625&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<Layout>
  <div class="space-y-4">
    <h1>Yo0's Portal</h1>
    <img class="aspect-3/2 max-h-48 rounded-xl object-cover" src={imageUrl} />
    <div class="flex gap-2">
      {
        links.map((link) => (
          <a
            href={link.url}
            class="transition-transform hover:scale-105 hover:transform hover:underline"
          >
            {link.name}
          </a>
        ))
      }
    </div>
  </div>
</Layout>
